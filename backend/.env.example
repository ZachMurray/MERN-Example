# Database
MONGODB_URI=mongodb://host.docker.internal:27017/mern-auth
MONGODB_FALLBACK_URI=mongodb://mongodb:27017/mern-auth
MONGODB_PRIMARY_RECHECK_INTERVAL_MS=15000
# For local development without Docker (backend run directly on host):
# MONGODB_URI=mongodb://localhost:27017/mern-auth

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
